{
  "name": "raman-studio",
  "productName": "RĀMAN Studio",
  "version": "1.0.0",
  "description": "Desktop electrochemical analysis — EIS, CV, GCD — by VidyuthLabs",
  "main": "src/desktop/main.js",
  "author": {
    "name": "VidyuthLabs",
    "email": "support@vidyuthlabs.co.in",
    "url": "https://vidyuthlabs.co.in"
  },
  "license": "SEE LICENSE IN LICENSE",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --win --linux",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^32.2.7",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.vidyuthlabs.raman.studio",
    "productName": "RĀMAN Studio",
    "copyright": "Copyright © 2026 VidyuthLabs",
    "directories": {
      "output": "build",
      "buildResources": "resources"
    },
    "files": [
      "src/**/*",
      "data/datasets/**/*",
      "engine_core/build/**/*",
      "engine_core/include/**/*",
      "!**/*.pyc",
      "!**/__pycache__",
      "!**/.git",
      "!**/.venv",
      "!**/.venv313",
      "!**/.venv_new",
      "!**/.history",
      "!**/.pytest_cache",
      "!**/node_modules/.cache",
      "!**/tests",
      "!**/dev_tools",
      "!**/docs",
      "!**/EIS-RV"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources"
      }
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "msi",  "arch": ["x64"] }
      ],
      "icon": "resources/icons/icon.ico",
      "artifactName": "${productName}-${version}-Setup.${ext}",
      "publisherName": "VidyuthLabs",
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "RĀMAN Studio",
      "license": "LICENSE_COMMERCIAL",
      "installerIcon": "resources/icons/icon.ico",
      "uninstallerIcon": "resources/icons/icon.ico",
      "installerHeaderIcon": "resources/icons/icon.ico"
    },
    "msi": {
      "oneClick": false,
      "perMachine": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "RĀMAN Studio"
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb",      "arch": ["x64"] }
      ],
      "icon": "resources/icons/icon.png",
      "category": "Science",
      "synopsis": "Desktop electrochemical analysis (EIS, CV, GCD)",
      "description": "Desktop companion for VidyuthLabs AnalyteX devices.",
      "desktop": {
        "Name": "RĀMAN Studio",
        "Comment": "Desktop companion for AnalyteX",
        "Categories": "Science;Education;Engineering;"
      }
    },
    "appImage": {
      "license": "LICENSE_COMMERCIAL"
    },
    "deb": {
      "depends": [
        "libnotify4",
        "libxtst6",
        "libnss3"
      ]
    },
    "publish": null
  }
}

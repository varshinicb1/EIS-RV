# VANL Environment Variables
# Copy this to .env and fill in your values

# API Configuration
PORT=8000
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1

# CORS (comma-separated origins)
ALLOWED_ORIGINS=*

# Optional: Database (for future use)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Optional: Redis Cache (for future use)
# REDIS_URL=redis://host:6379/0

# Optional: API Keys (for future authentication)
# API_KEY_SALT=your-secret-salt-here

# RĀMAN Studio — Example environment file
# Copy to .env, then fill in your own values. .env is gitignored; .env.example is committed.
# DO NOT put real secrets here.

# NVIDIA API Key — used only when AI features are explicitly invoked.
# Get one from https://build.nvidia.com (free tier available).
# Leave blank to run in fully-local mode (Qwen LoRA agent only).
NVIDIA_API_KEY=

# API Configuration
PORT=8000
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1

# CORS — comma-separated origins. Desktop builds need only 127.0.0.1.
# Never use "*" in any environment that ships externally.
ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# VANL Environment Configuration
# Copy this file to .env and fill in your values

# Application
APP_NAME=VANL
APP_VERSION=1.0.0
ENVIRONMENT=production  # development, staging, production
DEBUG=false
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Security
SECRET_KEY=your-secret-key-here-change-this-in-production
API_KEY_HEADER=X-API-Key
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Authentication (JWT)
JWT_SECRET_KEY=your-jwt-secret-key-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440  # 24 hours

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Database (PostgreSQL)
DATABASE_URL=postgresql://vanl:vanl_password@localhost:5432/vanl
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# Redis Cache
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# CORS
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*

# File Storage
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=100

# Research Pipeline
ENABLE_RESEARCH_PIPELINE=true
PIPELINE_SCHEDULE_HOURS=24

# Monitoring
ENABLE_METRICS=true
SENTRY_DSN=  # Optional: Add Sentry DSN for error tracking

# Email (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ADMIN_EMAIL=admin@yourdomain.com
